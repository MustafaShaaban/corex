# Corex environment — copy to `.env` (never commit `.env`; it is gitignored).
# Config resolution order: .env  →  WordPress options table  →  code defaults.

# ── Core ───────────────────────────────────────────────────────────────
COREX_ENV=local
COREX_DEBUG=true

# ── Internationalization ───────────────────────────────────────────────
# Driver behind the I18nHandler abstraction (polylang | wpml). See FRAMEWORK §16.
MWP_I18N_DRIVER=polylang

# ── Mail (Corex Mail add-on) ───────────────────────────────────────────
# Real credentials are encrypted at rest via the framework Cryptor — never store
# secrets in plaintext here. This file documents the keys, not their values.
COREX_MAIL_DRIVER=smtp
# COREX_MAIL_HOST=
# COREX_MAIL_PORT=587
# COREX_MAIL_USERNAME=
# COREX_MAIL_PASSWORD=

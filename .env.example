# Corex environment — copy to `.env` (never commit `.env`; it is gitignored).
# Config resolution order: .env  →  WordPress options table  →  code defaults.

# ── corex-core (active) ────────────────────────────────────────────────
# These map to config keys app.* — read via Config::get('app.name'), etc.
# Mapping: a dot key uppercases to an ENV name (app.name → APP_NAME).
APP_NAME=Corex
APP_ENV=local
# Debug surfacing (boot-problem admin notices) follows WP_DEBUG in wp-config.php,
# not an env var here.

# ── Internationalization ───────────────────────────────────────────────
# Driver behind the I18nHandler abstraction (polylang | wpml). See FRAMEWORK §16.
MWP_I18N_DRIVER=polylang

# ── Mail (Corex Mail add-on) ───────────────────────────────────────────
# Real credentials are encrypted at rest via the framework Cryptor — never store
# secrets in plaintext here. This file documents the keys, not their values.
COREX_MAIL_DRIVER=smtp
# COREX_MAIL_HOST=
# COREX_MAIL_PORT=587
# COREX_MAIL_USERNAME=
# COREX_MAIL_PASSWORD=

# ── Feature flags ──────────────────────────────────────────────────────
# Each flag maps features.<flag> → FEATURES_<FLAG>. Truthy = 1/true/on/yes.
# Read via Config::enabled('mail_queue') or the FeatureFlags service. A flag can
# also be flipped per-site by the WP option corex_features_<flag> (settings UI).
# FEATURES_PRO=0                 # Pro edition gate (Free build leaves it off)
# FEATURES_MAIL_QUEUE=0          # Action Scheduler bulk mail
# FEATURES_DATAVIEWS_ADMIN=0     # React/DataViews admin UI
# FEATURES_WOOCOMMERCE_KIT=0     # WooCommerce site kit

{
	"name": "{{ theme_slug }}-theme",
	"version": "0.1.0",
	"private": true,
	"description": "Frontend assets for the {{ name }} theme (Corex client site).",
	"scripts": {
		"build": "wp-scripts build assets/src/main.js --output-path=assets/build",
		"start": "wp-scripts start assets/src/main.js --output-path=assets/build"
	},
	"devDependencies": {
		"@wordpress/scripts": "^27.0.0"
	}
}

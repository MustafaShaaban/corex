{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "corex/modal",
	"title": "Corex Modal",
	"category": "corex",
	"icon": "external",
	"description": "An accessible dialog opened by a trigger button — native <dialog>, focus-trapped, ESC and backdrop to close, degrades without JS (dynamic).",
	"textdomain": "corex",
	"attributes": {
		"title": { "type": "string", "default": "" },
		"triggerLabel": { "type": "string", "default": "" },
		"content": { "type": "string", "default": "" }
	},
	"supports": { "html": false },
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style-index.css",
	"corex": { "renderer": "Corex\\Ui\\Blocks\\ModalRenderer" }
}

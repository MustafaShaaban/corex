{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Dark",
    "settings": {
        "color": {
            "palette": [
                { "slug": "primary", "color": "#00C2FF", "name": "Primary" },
                { "slug": "primary-dark", "color": "#7DD3FC", "name": "Primary dark" },
                { "slug": "accent", "color": "#7DD3FC", "name": "Accent" },

                { "slug": "surface-alt", "color": "#102A4C", "name": "Surface alt" },
                { "slug": "border", "color": "#71869C", "name": "Border" },
                { "slug": "ink", "color": "#F1F5F9", "name": "Ink" },
                { "slug": "ink-soft", "color": "#C3CEDA", "name": "Ink soft" },
                { "slug": "success", "color": "#4ADE80", "name": "Success" },
                { "slug": "warning", "color": "#FACC15", "name": "Warning" },
                { "slug": "error", "color": "#F87171", "name": "Error" },

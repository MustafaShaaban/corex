                { "slug": "inverse", "color": "#06121F", "name": "Inverse text" },
                { "slug": "overlay", "color": "rgba(0, 0, 0, 0.78)", "name": "Overlay" },
                { "slug": "selection", "color": "#075985", "name": "Selection" },

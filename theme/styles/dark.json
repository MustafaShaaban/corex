        "typography": {
            "fontFamilies": [
                { "slug": "heading", "name": "Heading", "fontFamily": "'Space Grotesk', system-ui, sans-serif" },
                { "slug": "arabic", "name": "Arabic", "fontFamily": "'IBM Plex Sans Arabic', system-ui, sans-serif" },
                { "slug": "body", "name": "Body", "fontFamily": "system-ui, sans-serif" },
                { "slug": "mono", "name": "Technical", "fontFamily": "'JetBrains Mono', ui-monospace, 'Cascadia Code', monospace" }
            ]

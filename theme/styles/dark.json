                { "slug": "background", "color": "#0B1F3B", "name": "Background (compatibility)" },
                { "slug": "foreground", "color": "#F1F5F9", "name": "Foreground (compatibility)" },
                { "slug": "danger", "color": "#F87171", "name": "Danger (compatibility)" },
                { "slug": "corex-danger", "color": "#F87171", "name": "CoreX danger (compatibility)" },
                { "slug": "corex-info", "color": "#60A5FA", "name": "CoreX info (compatibility)" },
                { "slug": "corex-primary", "color": "#00C2FF", "name": "CoreX primary (compatibility)" },
                { "slug": "corex-success", "color": "#4ADE80", "name": "CoreX success (compatibility)" },
                { "slug": "corex-warning", "color": "#FACC15", "name": "CoreX warning (compatibility)" },
                { "slug": "white", "color": "#06121F", "name": "White (compatibility)" }

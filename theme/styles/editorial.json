{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Editorial",
    "settings": {
        "color": {
            "palette": [
                { "slug": "primary", "color": "#1A1A1A", "name": "Primary" },
                { "slug": "primary-dark", "color": "#000000", "name": "Primary dark" },
                { "slug": "accent", "color": "#C8553D", "name": "Accent" },
                { "slug": "accent-dark", "color": "#A33E2A", "name": "Accent dark" },
                { "slug": "surface", "color": "#FBF8F1", "name": "Surface" },
                { "slug": "surface-alt", "color": "#F2ECDF", "name": "Surface alt" },
                { "slug": "border", "color": "#E0D8C8", "name": "Border" },
                { "slug": "ink", "color": "#1A1A1A", "name": "Ink" },
                { "slug": "ink-soft", "color": "#5C564C", "name": "Ink soft" },
                { "slug": "success", "color": "#286C3C", "name": "Success" },
                { "slug": "warning", "color": "#8A5A00", "name": "Warning" },
                { "slug": "error", "color": "#A33E2A", "name": "Error" },
                { "slug": "info", "color": "#345D8C", "name": "Info" },
                { "slug": "inverse", "color": "#FFFFFF", "name": "Inverse text" },
                { "slug": "overlay", "color": "rgba(26, 26, 26, 0.72)", "name": "Overlay" },
                { "slug": "selection", "color": "#F1C9BE", "name": "Selection" },
                { "slug": "selection-text", "color": "#1A1A1A", "name": "Selection text" },
                { "slug": "surface-raised", "color": "#FFFDF8", "name": "Raised surface" },
                { "slug": "surface-strong", "color": "#E8DFCF", "name": "Strong surface" },
                { "slug": "background", "color": "#FBF8F1", "name": "Background (compatibility)" },
                { "slug": "foreground", "color": "#1A1A1A", "name": "Foreground (compatibility)" },
                { "slug": "danger", "color": "#A33E2A", "name": "Danger (compatibility)" },
                { "slug": "corex-danger", "color": "#A33E2A", "name": "CoreX danger (compatibility)" },
                { "slug": "corex-info", "color": "#345D8C", "name": "CoreX info (compatibility)" },
                { "slug": "corex-primary", "color": "#1A1A1A", "name": "CoreX primary (compatibility)" },
                { "slug": "corex-success", "color": "#286C3C", "name": "CoreX success (compatibility)" },
                { "slug": "corex-warning", "color": "#8A5A00", "name": "CoreX warning (compatibility)" },
                { "slug": "white", "color": "#FFFFFF", "name": "White (compatibility)" }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "heading",
                    "name": "Heading",
                    "fontFamily": "'Space Grotesk', Georgia, 'Times New Roman', serif"
                },
                {
                    "slug": "arabic",
                    "name": "Arabic",
                    "fontFamily": "'IBM Plex Sans Arabic', system-ui, sans-serif"
                },
                {
                    "slug": "body",
                    "name": "Body",
                    "fontFamily": "system-ui, sans-serif"
                },
                {
                    "slug": "mono",
                    "name": "Technical",
                    "fontFamily": "'JetBrains Mono', ui-monospace, 'Cascadia Code', monospace"
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--surface)",
            "text": "var(--wp--preset--color--ink)"
        }
    }
}

# Corex house style. See https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# PHP follows PSR-12 — 4 spaces.
[*.php]
indent_style = space
indent_size = 4

# JS, blocks, styles, and JSON follow the WordPress editor convention — tabs.
[*.{js,jsx,ts,tsx,scss,css,json}]
indent_style = tab

# Block metadata + theme tokens are tab-indented JSON.
[{block.json,theme.json,brand.json}]
indent_style = tab

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
